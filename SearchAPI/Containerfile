FROM docker.io/library/python:3.13-slim

WORKDIR /app

COPY SearchAPI/requirements-searchapi.txt /app/
RUN pip install --no-cache-dir -r requirements-searchapi.txt

COPY credentials.py constants.py places.py /app/
# Copy the whole package; .dockerignore (repo root) keeps the Containerfile
# and __pycache__ out so we never silently ship a missing module again.
COPY SearchAPI/ /app/SearchAPI/

EXPOSE 8000

ENTRYPOINT ["uvicorn", "SearchAPI.main:app", \
            "--host", "0.0.0.0", "--port", "8000", \
            "--workers", "1", \
            "--proxy-headers", "--forwarded-allow-ips", "*"]