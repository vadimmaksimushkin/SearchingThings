# Build-context excludes. Named .dockerignore for docker/podman compatibility
# (buildah falls back to it when no .containerignore exists). The build context
# is the repo root (compose uses `context: ../..` / `.`), so this applies to
# every image build here. Only list things no build should ever COPY.

# Python bytecode — copying stale .pyc into an image can shadow updated source.
**/__pycache__/
**/*.pyc

# Containerfiles themselves never belong inside an image.
**/Containerfile
**/*.Containerfile

# Heavy/irrelevant trees: never COPYed, just bloat the context tarball.
.git/
.venv/
.ruff_cache/
.github/
